# Port tempat server Express mendengar (Vercel/PM2/systemd biasanya men-set ini).
PORT=8080

# Connection string PostgreSQL.
# Contoh: postgres://user:password@host:5432/mie_ayam_berteman
DATABASE_URL=

# Daftar origin yang boleh memanggil API (pisahkan dengan koma).
# Contoh: https://mieayamberteman.vercel.app,https://mieayamberteman.com
# Kosongkan untuk mengizinkan semua origin (kurang aman, hanya untuk testing).
CORS_ORIGIN=

# (opsional) "production" atau "development".
NODE_ENV=production
